{
  "name": "infrastructure-platform",
  "version": "1.0.0",
  "description": "Global Infrastructure Project & Investment Operating System",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "npm run -w apps/backend dev",
    "dev:frontend": "npm run -w apps/frontend dev",
    "db:migrate": "npm run -w apps/backend db:migrate",
    "db:seed": "npm run -w apps/backend db:seed",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "install": "npm install"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}

{
  "name": "@infrastructure-platform/backend",
  "version": "1.0.0",
  "description": "Global Infrastructure Platform - Backend Services",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "db:migrate": "ts-node src/database/migrations/run.ts",
    "db:seed": "ts-node src/database/seeds/run.ts",
    "db:reset": "npm run db:migrate -- --reset && npm run db:seed",
    "health-check": "ts-node src/scripts/health-check.ts",
    "docker:build": "docker build -t infrastructure-platform:backend .",
    "docker:run": "docker run -p 3001:3001 infrastructure-platform:backend"
  },
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.0.0",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "pg": "^8.10.0",
    "redis": "^4.6.5",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "joi": "^17.9.2",
    "express-rate-limit": "^6.7.0",
    "uuid": "^9.0.0",
    "winston": "^3.8.2",
    "axios": "^1.4.0",
    "crypto": "^1.0.1",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.0",
    "nodemailer": "^6.9.3",
    "twilio": "^3.74.0",
    "aws-sdk": "^2.1400.0",
    "stripe": "^12.0.0",
    "bull": "^4.10.4",
    "express-async-errors": "^3.1.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "typeorm": "^0.3.15"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "prettier": "^2.8.8",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
